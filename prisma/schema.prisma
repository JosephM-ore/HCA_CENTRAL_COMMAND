generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   // ADMIN, TRADER, ANALYST, PM, VIEWER, COMPLIANCE

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  comments     Comment[]
  auditLogs    AuditLog[]
  flagsCreated Flag[]   @relation("FlagsCreated")
  flagsResolved Flag[]  @relation("FlagsResolved")
  sessions Session[]
}
model Session {
  id        String   @id @default(cuid())
  token     String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())
}
model Security {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  sector    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions        Position[]
  trades           Trade[]
  watchlistEntries WatchlistEntry[]
  comments         Comment[]
  flags            Flag[]
  marketData       MarketDataCache[]
}

model Position {
  id              String   @id @default(cuid())

  securityId      String
  security        Security @relation(fields: [securityId], references: [id])

  side            String   // LONG, SHORT
  status          String   // ACTIVE, CLOSED

  shares          Float?
  wap             Float?
  marketValue     Float?
  portfolioPct    Float?
  totalPctChange  Float?
  dayPctChange    Float?

  exitRationale   String?

  openedAt        DateTime?
  closedAt        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trades          Trade[]
  comments        Comment[]
  flags           Flag[]
}

model Trade {
  id          String   @id @default(cuid())

  securityId  String
  security    Security @relation(fields: [securityId], references: [id])

  positionId  String?
  position    Position? @relation(fields: [positionId], references: [id])

  dateTraded  DateTime
  shares      Float
  avgPrice    Float
  ptHistory   String?
  comment     String?

  createdAt   DateTime @default(now())
}

model WatchlistEntry {
  id          String   @id @default(cuid())

  securityId  String
  security    Security @relation(fields: [securityId], references: [id])

  side        String   // LONG, SHORT
  targetPrice Float?
  notes       String?

  archivedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    Comment[]
  flags       Flag[]
}

model Comment {
  id                String   @id @default(cuid())

  securityId        String
  security          Security @relation(fields: [securityId], references: [id])

  positionId        String?
  position          Position? @relation(fields: [positionId], references: [id])

  watchlistEntryId  String?
  watchlistEntry    WatchlistEntry? @relation(fields: [watchlistEntryId], references: [id])

  authorId          String
  author            User     @relation(fields: [authorId], references: [id])

  tag               String   // COMMENT, THESIS, RISK, CATALYST, TRADE, EXIT
  content           String

  isPinned          Boolean  @default(false)
  archivedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Flag {
  id                String   @id @default(cuid())

  securityId        String
  security          Security @relation(fields: [securityId], references: [id])

  positionId        String?
  position          Position? @relation(fields: [positionId], references: [id])

  watchlistEntryId  String?
  watchlistEntry    WatchlistEntry? @relation(fields: [watchlistEntryId], references: [id])

  flagType          String
  description       String?

  priority          String   // LOW, MEDIUM, HIGH
  status            String   @default("OPEN") // OPEN, RESOLVED, ARCHIVED

  createdById       String
  createdBy         User     @relation("FlagsCreated", fields: [createdById], references: [id])

  resolvedById      String?
  resolvedBy        User?    @relation("FlagsResolved", fields: [resolvedById], references: [id])

  createdAt         DateTime @default(now())
  resolvedAt        DateTime?
}

model MarketDataCache {
  id                String   @id @default(cuid())

  securityId        String
  security          Security @relation(fields: [securityId], references: [id])

  currentPrice      Float?
  vwap              Float?
  high52w           Float?
  low52w            Float?
  beta              Float?
  avgVolume         Float?
  shortFloat        Float?
  marketCap         Float?

  peLtm             Float?
  priceToTangBook   Float?
  peNtm             Float?
  priceToBook       Float?
  debtToEbitda      Float?
  eps               Float?

  source            String   @default("MOCK")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model IngestionRun {
  id          String   @id @default(cuid())

  source      String   // WELLS_FARGO, BLOOMBERG, MANUAL
  status      String   // STARTED, COMPLETED, FAILED
  message     String?

  startedAt   DateTime @default(now())
  endedAt     DateTime?
}

model AuditLog {
  id                String   @id @default(cuid())

  actorId           String
  actor             User     @relation(fields: [actorId], references: [id])

  action            String
  entityType        String
  entityId          String

  previousValueJson String?
  newValueJson      String?

  ipAddress         String?
  userAgent         String?

  createdAt         DateTime @default(now())
}