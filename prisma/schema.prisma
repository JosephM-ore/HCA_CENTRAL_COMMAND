generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  role         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments            Comment[]
  auditLogs           AuditLog[]
  flagsCreated        Flag[]               @relation("FlagsCreated")
  flagsResolved       Flag[]               @relation("FlagsResolved")
  sessions            Session[]
  fundEquitySnapshots FundEquitySnapshot[] @relation("FundEquitySnapshotsEnteredBy")

  registrationApprovalsCreated RegistrationApproval[] @relation("RegistrationApprovalsApprovedBy")
  registrationApproval         RegistrationApproval?  @relation("RegistrationApprovalRegisteredUser")
}

model FundEquitySnapshot {
  id String @id @default(cuid())

  asOfDate  DateTime @unique
  netEquity Float

  source String  @default("MANUAL")
  note   String?

  enteredById String
  enteredBy   User   @relation("FundEquitySnapshotsEnteredBy", fields: [enteredById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enteredById])
}

model Session {
  id    String @id @default(cuid())
  token String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Meeting {
  id String @id @default(cuid())

  title String

  meetingDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]

  @@index([meetingDate])
}

model Security {
  id              String  @id @default(cuid())
  ticker          String  @unique
  name            String
  sector          String?
  industry        String?
  exchange        String?
  cik             String?
  securityType    String?
  wellsSecurityId String?
  cusip           String?
  isin            String?
  sedol           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taxLots          TaxLot[]
  positions        Position[]
  trades           Trade[]
  watchlistEntries WatchlistEntry[]
  comments         Comment[]
  flags            Flag[]
  marketData       MarketDataCache[]

  @@index([cik])
}

model Position {
  id String @id @default(cuid())

  securityId String
  security   Security @relation(fields: [securityId], references: [id])

  source           String?
  accountNumber    String?
  custodian        String?
  costBasis        Float?
  unrealizedPnl    Float?
  sourceReportDate DateTime?
  sourceFileName   String?
  sourceRowHash    String?
  ingestionRunId   String?

  side   String // LONG, SHORT
  status String // ACTIVE, CLOSED

  shares         Float?
  wap            Float?
  marketValue    Float?
  portfolioPct   Float?
  totalPctChange Float?
  dayPctChange   Float?

  exitRationale String?

  openedAt DateTime?
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taxLots  TaxLot[]
  trades   Trade[]
  comments Comment[]
  flags    Flag[]
}

model TaxLot {
  id String @id @default(cuid())

  securityId String
  security   Security @relation(fields: [securityId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  accountNumber String?
  taxLotId      String?
  taxLotDate    DateTime?

  quantity       Float?
  unitCost       Float?
  marketPrice    Float?
  costBasis      Float?
  marketValue    Float?
  unrealizedPnl  Float?
  roi            Float?
  holdingPeriod  String?
  daysToLongTerm String?

  source           String?
  sourceFileName   String?
  sourceRowHash    String    @unique
  sourceReportDate DateTime?
  ingestionRunId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([securityId])
  @@index([positionId])
  @@index([taxLotDate])
  @@index([sourceReportDate])
}

model Trade {
  id String @id @default(cuid())

  securityId String
  security   Security @relation(fields: [securityId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  dateTraded        DateTime
  shares            Float
  avgPrice          Float
  tradeType         String?
  settlementDate    DateTime?
  postDate          DateTime?
  notional          Float?
  commission        Float?
  fees              Float?
  accruedInterest   Float?
  netAmount         Float?
  currency          String?
  transactionId     String?
  clientReferenceId String?
  source            String?
  sourceFileName    String?
  sourceRowHash     String?
  sourceReportDate  DateTime?
  ingestionRunId    String?
  ptHistory         String?
  comment           String?

  reconciliationStatus  String? // MANUAL_PENDING, MATCHED, REVIEW_REQUIRED, SUPERSEDED_BY_WELLS, UNMATCHED
  reconciliationGroupId String?
  matchedTradeId        String?
  reconciledAt          DateTime?
  reconciliationNotes   String?
  manualEnteredById     String?
  isHidden              Boolean   @default(false)

  createdAt DateTime @default(now())
}

model WatchlistEntry {
  id String @id @default(cuid())

  securityId String
  security   Security @relation(fields: [securityId], references: [id])

  side String // LONG, SHORT

  // Legacy target retained temporarily for safe host upgrades.
  targetPrice Float?

  // LONG: entry = Buy PT, exit = Sell PT
  // SHORT: entry = Sell PT, exit = Cover PT
  entryTargetPrice Float?
  exitTargetPrice  Float?

  notes String?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
  flags    Flag[]
}

model Comment {
  id String @id @default(cuid())

  securityId String?
  security   Security? @relation(fields: [securityId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  watchlistEntryId String?
  watchlistEntry   WatchlistEntry? @relation(fields: [watchlistEntryId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  tag     String // COMMENT, NOTE, THESIS, RISK, CATALYST, TRADE, EXIT
  content String

  isPinned   Boolean   @default(false)
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id])
}

model Flag {
  id String @id @default(cuid())

  securityId String?
  security   Security? @relation(fields: [securityId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  watchlistEntryId String?
  watchlistEntry   WatchlistEntry? @relation(fields: [watchlistEntryId], references: [id])

  flagType    String
  description String?
  reminderAt  DateTime?

  priority String // LOW, MEDIUM, HIGH
  status   String @default("OPEN") // OPEN, RESOLVED, ARCHIVED

  createdById String
  createdBy   User   @relation("FlagsCreated", fields: [createdById], references: [id])

  resolvedById String?
  resolvedBy   User?   @relation("FlagsResolved", fields: [resolvedById], references: [id])

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  metadataJson String?
}

model MarketDataCache {
  id String @id @default(cuid())

  securityId String
  security   Security @relation(fields: [securityId], references: [id])

  currentPrice        Float?
  vwap                Float?
  high52w             Float?
  low52w              Float?
  beta                Float?
  avgVolume           Float?
  shortFloat          Float?
  marketCap           Float?
  dayChange           Float?
  dayPctChange        Float?
  volume              Float?
  sharesOutstanding   Float?
  floatShares         Float?
  shortInterestShares Float?

  peLtm                     Float?
  priceToTangBook           Float?
  peNtm                     Float?
  priceToBook               Float?
  debtToEbitda              Float?
  eps                       Float?
  epsTtm                    Float?
  epsNtm                    Float?
  bookValue                 Float?
  bookValuePerShare         Float?
  tangibleBookValue         Float?
  tangibleBookValuePerShare Float?
  enterpriseValue           Float?
  ebitda                    Float?
  totalDebt                 Float?
  revenue                   Float?
  revenueTtm                Float?
  grossProfit               Float?
  operatingIncome           Float?
  netIncome                 Float?
  netIncomeTtm              Float?
  cashAndEquivalents        Float?
  totalAssets               Float?
  totalLiabilities          Float?
  shareholdersEquity        Float?

  source                     String    @default("MOCK")
  marketDataSource           String?
  fundamentalsSource         String?
  shortInterestSource        String?
  snapshotAsOf               DateTime?
  fundamentalsAsOf           DateTime?
  shortInterestAsOf          DateTime?
  dataQuality                String?
  sourceDetailJson           String?
  lastMarketDataRefreshAt    DateTime?
  lastFundamentalsRefreshAt  DateTime?
  lastShortInterestRefreshAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([securityId])
  @@index([updatedAt])
}

model IngestionRun {
  id String @id @default(cuid())

  source           String // WELLS_FARGO, BLOOMBERG, MANUAL
  status           String // STARTED, COMPLETED, FAILED
  message          String?
  fileName         String?
  fileType         String?
  fileHash         String?
  sourceReportDate DateTime?
  rowsProcessed    Int?
  rowsFailed       Int?
  detailsJson      String?
  accountNumber    String?

  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

model AuditLog {
  id String @id @default(cuid())

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action     String
  entityType String
  entityId   String

  previousValueJson String?
  newValueJson      String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
}

model RegistrationApproval {
  id String @id @default(cuid())

  email  String @unique
  role   String
  status String @default("PENDING")

  approvedById String
  approvedBy   User   @relation("RegistrationApprovalsApprovedBy", fields: [approvedById], references: [id])

  registeredUserId String? @unique
  registeredUser   User?   @relation("RegistrationApprovalRegisteredUser", fields: [registeredUserId], references: [id])

  approvedAt   DateTime  @default(now())
  registeredAt DateTime?
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([approvedById])
}
